const { PrismaClient } = require('@prisma/client')

const prisma = new PrismaClient()

async function main() {
  console.log('🌱 Sembrando datos de prueba...')

  try {
    // Verificar conexión
    await prisma.$connect()
    console.log('✅ Conectado a la base de datos')

    // Crear usuario admin
    const admin = await prisma.user.upsert({
      where: { email: 'admin@biblioteca.com' },
      update: {},
      create: {
        email: 'admin@biblioteca.com',
        name: 'Administrador',
        password: 'admin123',
        role: 'admin',
        phone: '123456789',
      },
    })
    console.log('✅ Admin creado:', admin.email)

    // Crear usuario normal
    const user = await prisma.user.upsert({
      where: { email: 'usuario@biblioteca.com' },
      update: {},
      create: {
        email: 'usuario@biblioteca.com',
        name: 'Usuario Test',
        password: 'user123',
        role: 'user',
        phone: '987654321',
      },
    })
    console.log('✅ Usuario creado:', user.email)

    // Crear libro 1
    const book1 = await prisma.book.upsert({
      where: { isbn: '978-3-16-148410-0' },
      update: {},
      create: {
        title: 'El Principito',
        author: 'Antoine de Saint-Exupéry',
        isbn: '978-3-16-148410-0',
        publisher: 'Editorial Ejemplo',
        year: 1943,
        description: 'Un clásico de la literatura infantil.',
        copies: {
          create: [
            { status: 'available' },
            { status: 'available' },
          ],
        },
      },
    })
    console.log('✅ Libro creado:', book1.title)

    // Crear libro 2
    const book2 = await prisma.book.upsert({
      where: { isbn: '978-0-06-112008-4' },
      update: {},
      create: {
        title: 'Cien Años de Soledad',
        author: 'Gabriel García Márquez',
        isbn: '978-0-06-112008-4',
        publisher: 'Editorial Sudamericana',
        year: 1967,
        description: 'La historia de la familia Buendía.',
        copies: {
          create: [
            { status: 'available' },
          ],
        },
      },
    })
    console.log('✅ Libro creado:', book2.title)

    // Obtener ejemplares del libro 1
    const copies = await prisma.copy.findMany({
      where: { bookId: book1.id },
    })

    // Crear préstamos
    if (copies.length >= 2) {
      // Préstamo activo
      await prisma.loan.create({
        data: {
          userId: user.id,
          copyId: copies[0].id,
          dueDate: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000),
          status: 'active',
        },
      })
      console.log('✅ Préstamo activo creado')

      // Préstamo vencido
      await prisma.loan.create({
        data: {
          userId: admin.id,
          copyId: copies[1].id,
          dueDate: new Date(Date.now() - 3 * 24 * 60 * 60 * 1000),
          status: 'overdue',
        },
      })
      console.log('✅ Préstamo vencido creado')
    }

    // Resumen
    console.log('\n📊 Resumen de datos:')
    console.log('📚 Libros:', await prisma.book.count())
    console.log('👥 Usuarios:', await prisma.user.count())
    console.log('📋 Préstamos activos:', await prisma.loan.count({ where: { status: 'active' } }))
    console.log('⚠️ Préstamos vencidos:', await prisma.loan.count({ where: { status: 'overdue' } }))
    console.log('\n✅ ¡Datos creados exitosamente!')

  } catch (error) {
    console.error('❌ Error:', error)
  } finally {
    await prisma.$disconnect()
  }
}

main()